# =============================================================================
# Central configuration. docker-compose substitutes ${VARS} from this file,
# and your Python services read the same values via os.getenv(). One source of
# truth for addresses, topic names, and tuning knobs.
# =============================================================================

# --- Producer Loop Control ---------------------------------------------------
# Set to 'false' to run once and stop cleanly. Set to 'true' to loop forever.
PRODUCER_LOOP_FOREVER=false

# --- Kafka addresses ---------------------------------------------------------
# Host scripts (running in your .venv) use this:
KAFKA_BOOTSTRAP_HOST=localhost:9092
# Containers (on the internal Docker network) use this:
KAFKA_BOOTSTRAP_INTERNAL=kafka:29092

# --- Topic names -------------------------------------------------------------
TOPIC_RAW_TRACKS=raw-tracks
TOPIC_PREDICTIONS=predictions
TOPIC_DRIFT_ALERTS=drift-alerts

# --- Producer tuning ---------------------------------------------------------
# Seconds between emitted tracks. Lower = faster stream. 0.1 is a good demo pace.
PRODUCER_DELAY_SECONDS=0.1

# --- Drift detection tuning (used in Step 5) ---------------------------------
# Sliding window size for the KS test (number of recent messages compared
# against the training reference distribution).
DRIFT_WINDOW_SIZE=300
# KS test p-value below this => flag data drift.
DRIFT_KS_PVALUE=0.05

# --- KRaft cluster identity --------------------------------------------------
# A fixed cluster ID so the broker's stored metadata stays consistent across
# restarts. Any valid base64-ish 22-char string works; this one is fine to keep.
CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk